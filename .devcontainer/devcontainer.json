{
	"name": "Odoo Development",
	"dockerComposeFile": "../docker-compose.yml",
	"service": "odoo",
	"runServices": ["odoo", "postgres"],
	"shutdownAction": "stopCompose",
	"workspaceFolder": "/mnt/extra-addons",
	"overrideCommand": true,
	"remoteUser": "odoo",
	"containerEnv": {
		"PIP_NO_CACHE_DIR": "1",
		"PYTHONDONTWRITEBYTECODE": "1",
		"DEBIAN_FRONTEND": "noninteractive",
		"NODE_OPTIONS": "--max-old-space-size=4096"
	},
	"mounts": [
		{
			"source": "${localEnv:HOME}/.claude",
			"target": "/var/lib/odoo/.claude",
			"type": "bind"
		},
		{
			"source": "${localEnv:HOME}/.claude.json",
			"target": "/var/lib/odoo/.claude.json",
			"type": "bind"
		}
	],
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"editor.quickSuggestions": {
					"other": true,
					"comments": true,
					"strings": true
				},
				"files.watcherInclude": [
					"/mnt/extra-addons/**"
				],
				"python.defaultInterpreterPath": "/usr/bin/python3",
				"python.languageServer": "Pylance",
				"python.analysis.completeFunctionParens": true,
				"python.analysis.autoImportCompletions": true,
				"python.analysis.typeCheckingMode": "basic",
				"python.analysis.persistAllIndices": true,
				"python.analysis.extraPaths": [
					"/usr/lib/python3/dist-packages/odoo", 
				],
				"python.analysis.indexing": true,
				"python.analysis.packageIndexDepths": [
					{ "name": "odoo", "depth": 10 }
				],
				"python.linting.enabled": true,
				"python.linting.pylintEnabled": true,
				"python.linting.pylintArgs": [
					"--load-plugins=pylint_odoo",
					"--valid-odoo-versions=19.0",
					"--rcfile=/mnt/extra-addons/.pylintrc"
				],
				"python.editor.defaultFormatter": "ms-python.black-formatter",
				"python.editor.formatOnSave": true,
				"python.editor.codeActionsOnSave": {
					"source.organizeImports": true
				},
				"files.watcherExclude": {
					"**/node_modules/**": true,
					"**/filestore/**": true,
					"**/__pycache__/**": true,
					"**/.git/**": true
				},
				"extensions.autoUpdate": false,
				"telemetry.telemetryLevel": "off",
			},
			"xml.validation.enabled": true,
			"emmet.includeLanguages": {
			"xml": "html"
			},
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-python.pylint", 
				"ms-python.flake8",
				"ms-python.black-formatter",
				"ms-python.debugpy",
				"redhat.vscode-xml",
				"jigar-patel.OdooSnippets",
				"mechatroner.rainbow-csv",
				"formulahendry.auto-rename-tag",
				"anthropic.claude-code",
			]
		}
	},
	"postCreateCommand": "bash /usr/local/bin/post-create.sh",
	"forwardPorts": [8069, 1080]
}